# Orya v3 — Variables d'Environnement Complètes

# ── LLM Providers ─────────────────────────────────────────────────
GROQ_API_KEY=
NVIDIA_API_KEY=
CEREBRAS_API_KEY=
OPENROUTER_API_KEY=
HUGGINGFACE_API_KEY=

# ── Graphiti / Neo4j ──────────────────────────────────────────────
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
GRAPHITI_LLM_PROVIDER=openrouter
GRAPHITI_LLM_MODEL=meta-llama/llama-4-maverick-17b-128e-instruct
GRAPHITI_LLM_SMALL_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
SEMAPHORE_LIMIT=5
GRAPHITI_TELEMETRY_ENABLED=false

# ── PostgreSQL ────────────────────────────────────────────────────
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=orya
POSTGRES_USER=orya
POSTGRES_PASSWORD=

# ── LangSmith Observabilité ───────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=orya-production

# ── Qdrant (Vector DB) ────────────────────────────────────────────
QDRANT_HOST=127.0.0.1
QDRANT_PORT=6333
EMBEDDING_DIM=384

# ── Services internes ─────────────────────────────────────────────
AGENT_URL=http://127.0.0.1:5001
GRAPHITI_SERVER_URL=http://127.0.0.1:8000
GATEWAY_PORT=4001
GATEWAY_INTERNAL_URL=http://127.0.0.1:4001

# ── Tuning ────────────────────────────────────────────────────────
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=512
SEARCH_NUM_RESULTS_CONTEXT=5
SEARCH_NUM_RESULTS_MATCH=20
OPT_IN_TTL_HOURS=72

# ── Security ──────────────────────────────────────────────────────
INTERNAL_API_KEY=
