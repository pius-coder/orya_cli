# ============================================================
# Orya v2 — environment variables
# Copy to .env and fill the secrets before running.
# ============================================================

# ── LLM providers (at least one required) ────────────────────────
GROQ_API_KEY="gsk_..."
NVIDIA_API_KEY="nvapi-..."
CEREBRAS_API_KEY="csk-..."
OPENROUTER_API_KEY="sk-or-v1-..."

# ── Embeddings (HuggingFace serverless) ──────────────────────────
HUGGINGFACE_API_KEY="hf_..."

# ── Graphiti tuning ──────────────────────────────────────────────
GRAPHITI_LLM_MODEL="meta-llama/llama-4-scout-17b-16e-instruct"
GRAPHITI_LLM_SMALL_MODEL="llama-3.1-8b-instant"
SEMAPHORE_LIMIT="5"
GRAPHITI_TELEMETRY_ENABLED="false"

# ── Neo4j ────────────────────────────────────────────────────────
NEO4J_URI="bolt://127.0.0.1:7687"
NEO4J_USER="neo4j"
NEO4J_PASSWORD=""

# ── PostgreSQL (used by both LangGraph PostgresSaver and orya schema) ──
POSTGRES_HOST="127.0.0.1"
POSTGRES_PORT="5432"
POSTGRES_DB="orya"
POSTGRES_USER="orya"
POSTGRES_PASSWORD="orya_secret_2026"

# ── Internal service URLs (loopback inside the container) ────────
AGENT_URL="http://127.0.0.1:5001"
GRAPHITI_SERVER_URL="http://127.0.0.1:8000"
GATEWAY_INTERNAL_URL="http://127.0.0.1:4001"

# ── Gateway runtime ──────────────────────────────────────────────
GATEWAY_PORT="4001"

# ── LLM tuning (overrides for the persona) ───────────────────────
LLM_TEMPERATURE="0.7"
LLM_MAX_TOKENS="512"

# ── Search tuning ────────────────────────────────────────────────
SEARCH_NUM_RESULTS_CONTEXT="5"
SEARCH_NUM_RESULTS_MATCH="10"
OPT_IN_TTL_HOURS="72"

# ── LangSmith (optional but recommended for observability) ───────
LANGSMITH_TRACING="false"
LANGSMITH_API_KEY=""
LANGSMITH_PROJECT="orya-v2"

# ── Logging ──────────────────────────────────────────────────────
LOG_LEVEL="INFO"
