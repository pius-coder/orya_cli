# ── LLM Providers (all OpenAI-compatible) ─────────────────────────
OPENROUTER_API_KEY="sk-or-v1-..."
NVIDIA_API_KEY="nvapi-..."
GROQ_API_KEY="gsk_..."
CEREBRAS_API_KEY="csk-..."
HUGGINGFACE_API_KEY="hf_..."

# ── Vector Search (Qdrant) — used for fast profile similarity ─────
# Qdrant is a SUPPLEMENTARY search layer on top of Graphiti.
# Graphiti handles the main knowledge graph + hybrid search.
# Qdrant is used for quick fuzzy profile matching when needed.
QDRANT_URL="https://qdrantorya.globalimex.online"
QDRANT_API_KEY=""

# ── Graph DB (FalkorDB) — used BY Graphiti internally ─────────────
FALKORDB_HOST="127.0.0.1"
FALKORDB_PORT="6379"

# ── Service URLs (internal docker network) ────────────────────────
AGENT_ORYA_URL="http://127.0.0.1:5001"
ORCHESTRATOR_URL="http://127.0.0.1:5002"
MEMORY_URL="http://127.0.0.1:5003"
GATEWAY_URL="http://127.0.0.1:4001"

# ── Gateway ───────────────────────────────────────────────────────
GATEWAY_PORT="4001"
